// Prisma schema for IT&D Management System
// Using MySQL for production

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum EducationSystem {
  THREE_YEAR
  FIVE_YEAR
}

enum CourseType {
  PUBLIC
  MAJOR
}

enum CourseSourceType {
  MANUAL
  PLAN_IMPORT
}

enum CourseStatus {
  ACTIVE
  DISABLED
}

enum GradeStatus {
  ACTIVE
  GRADUATED
}

enum TeachingPlanTermType {
  SCHOOL
  INTERNSHIP
}

// 用户表
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  name      String
  email     String   @unique
  phone     String?
  phonePublic Boolean @default(false)  // 手机号是否公开
  emailPublic Boolean @default(false)  // 邮箱是否公开
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account?
}

// 账号表
model Account {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  
  password    String
  accountType String
  status      String   @default("PENDING_APPROVAL")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 权限表
model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  module      String
  description String?
  
  createdAt   DateTime @default(now())
  
  rolePermissions RolePermission[]
}

// 角色权限表
model RolePermission {
  id           String     @id @default(cuid())
  accountType  String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  
  createdAt   DateTime   @default(now())
  
  @@unique([accountType, permissionId])
}

// 专业表
model Major {
  id              String            @id @default(cuid())
  name            String            @unique
  educationSystem EducationSystem
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  grades          Grade[]
  courses         Course[]
}

// 年级表
model Grade {
  id              String            @id @default(cuid())
  name            String
  majorId         String
  major           Major             @relation(fields: [majorId], references: [id])
  educationSystem EducationSystem
  status          GradeStatus       @default(ACTIVE)
  graduatedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  teachingPlans   TeachingPlan[]

  @@index([majorId])
  @@index([status])
  @@unique([majorId, name])
}

// 课程表
model Course {
  id               String            @id @default(dbgenerated("(uuid())")) @db.Char(36)
  name             String
  weeklyHours      Decimal?          @db.Decimal(10, 2)
  courseType       CourseType
  sourceType       CourseSourceType  @default(MANUAL)
  status           CourseStatus      @default(ACTIVE)
  majorId          String?
  major            Major?            @relation(fields: [majorId], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  teachingPlanRows TeachingPlanRow[]

  @@index([majorId])
  @@index([courseType])
  @@unique([courseType, name])
  @@unique([majorId, name])
}

// 教学计划表
model TeachingPlan {
  id          String            @id @default(cuid())
  gradeId     String
  grade       Grade             @relation(fields: [gradeId], references: [id])
  name        String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  rows        TeachingPlanRow[]

  @@index([gradeId])
}

// 教学计划行表
model TeachingPlanRow {
  id               String               @id @default(cuid())
  teachingPlanId   String
  teachingPlan     TeachingPlan         @relation(fields: [teachingPlanId], references: [id])
  termNo           Int
  termType         TeachingPlanTermType
  courseName       String
  courseId         String?              @db.Char(36)
  course           Course?              @relation(fields: [courseId], references: [id])
  weeklyHoursRaw   String
  weeklyHoursValue Decimal?             @db.Decimal(10, 2)
  teacherName      String?
  remark           String?
  sortOrder        Int                  @default(0)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([teachingPlanId])
  @@index([courseId])
  @@index([termNo, termType])
}
